---
import Logo from "@/components/logo.astro";
---

<footer class="bg-secondary text-white">
  <div class="border-b border-gray-700 py-24">
    <div class="container mx-auto grid grid-cols-3 items-center">
      <a href="mailto:info@zaehringer-huette.de" class="text-center">
        <span
          aria-hidden="true"
          class="mx-auto mb-2 grid aspect-square w-16 place-items-center rounded-full border border-gray-700"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 512 512"
            width="24"
            height="24"
          >
            <path
              fill="currentColor"
              d="M64 112c-8.8 0-16 7.2-16 16v22.1L220.5 291.7c20.7 17 50.4 17 71.1 0L464 150.1V128c0-8.8-7.2-16-16-16H64zM48 212.2V384c0 8.8 7.2 16 16 16H448c8.8 0 16-7.2 16-16V212.2L322 328.8c-38.4 31.5-93.7 31.5-132 0L48 212.2zM0 128C0 92.7 28.7 64 64 64H448c35.3 0 64 28.7 64 64V384c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V128z"
            ></path>
          </svg>
        </span>

        info@zaehringer-huette.de
      </a>

      <div>
        <Logo />

        <p
          class="relative mt-8 pt-8 text-center before:absolute before:left-1/2 before:top-0 before:h-px before:w-1/4 before:-translate-x-1/2 before:bg-gray-700"
        >
          Dr. Freddy Stober Weg 8<br />
          79868 Feldberg (Schwarzwald)<br />
          Deutschland
        </p>
      </div>

      <a href="tel:+491739940283" class="text-center">
        <span
          aria-hidden="true"
          class="mx-auto mb-2 grid aspect-square w-16 place-items-center rounded-full border border-gray-700"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 512 512"
            width="24"
            height="24"
          >
            <path
              fill="currentColor"
              d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"
            ></path>
          </svg>
        </span>

        +49 (0)173 9940 283
      </a>
    </div>
  </div>

  <div class="container mx-auto py-8 text-center">
    <p>
      &copy; {new Date().getFullYear()} Familie Effinger. Alle Rechte vorbehalten.
    </p>

    <nav class="mt-4 space-x-8">
      <a href="#">Datenschutz</a>
      <a href="#">Impressum</a>
    </nav>
  </div>
</footer>
